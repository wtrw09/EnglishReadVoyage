# EnglishReadVoyage 后端环境配置示例
# 复制此文件为 .env 并根据实际需求修改

# ========== 基础配置 ==========
# 调试模式 - 开发环境启用自动热重载
DEBUG=True

# 生产环境标志 - 设为 True 时强制要求配置 SECRET_KEY
IS_PRODUCTION=False

# 服务器配置
HOST=0.0.0.0
PORT=8000

# ========== 安全配置 (重要) ==========
# JWT 密钥 - 生产环境必须设置！
# 建议使用至少 32 字符的随机字符串，例如：
# SECRET_KEY=your-super-secret-key-at-least-32-chars-here
SECRET_KEY=

# 令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30
INVITATION_CODE_EXPIRE_MINUTES=10080

# ========== CORS 配置 ==========
# 跨域来源（逗号分隔多个域名）
# 开发环境: * (允许所有)
# 生产环境: http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=*

# ========== TTS 语音合成配置 ==========
# 默认 TTS 服务 (kokoro-tts, doubao-tts, siliconflow-tts, edge-tts, minimax-tts)
DEFAULT_TTS_SERVICE=edge-tts

# Kokoro TTS API 配置
KOKORO_API_URL=http://localhost:8880/v1/audio/speech
KOKORO_DEFAULT_VOICE=bf_v0isabella
KOKORO_DEFAULT_VOICE_ZH=zf_xiaoxiao
KOKORO_DEFAULT_SPEED=1.0
TTS_TIMEOUT=30.0

# 豆包 TTS API 配置
DOUBAO_API_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional
DOUBAO_DEFAULT_VOICE=zh_female_yingyujiaoyu_mars_bigtts
DOUBAO_DEFAULT_RESOURCE_ID=seed-tts-1.0
DOUBAO_DEFAULT_SPEED=1.0
# DOUBAO_APP_ID=your_app_id_here
# DOUBAO_ACCESS_KEY=your_access_key_here

# 硅基流动 TTS API 配置
SILICONFLOW_API_URL=https://api.siliconflow.cn/v1/audio/speech
SILICONFLOW_DEFAULT_MODEL=fnlp/MOSS-TTSD-v0.5
SILICONFLOW_DEFAULT_VOICE=anna
# SILICONFLOW_API_KEY=your_api_key_here

# Edge-TTS 配置（微软在线TTS，免费但需安装 edge-tts）
EDGE_TTS_DEFAULT_VOICE=en-US-AriaNeural
EDGE_TTS_DEFAULT_VOICE_ZH=zh-CN-XiaoxiaoNeural
EDGE_TTS_DEFAULT_SPEED=1.0

# MiniMax TTS API 配置
MINIMAX_API_URL=https://api.minimaxi.com/v1/t2a_v2
MINIMAX_DEFAULT_MODEL=speech-2.8-hd
MINIMAX_DEFAULT_VOICE=male-qn-qingse
MINIMAX_DEFAULT_SPEED=1.0
# MINIMAX_API_KEY=your_api_key_here

# Azure TTS API 配置
# AZURE_TTS_SUBSCRIPTION_KEY=your_subscription_key_here
# AZURE_TTS_REGION=eastasia  # 例如: eastasia, southeastasia, westeurope, northeurope, eastus, westus 等

# ========== 路径配置 (可选) ==========
# Books 目录路径，不设置则使用默认路径
# BOOKS_DIR=/path/to/Books

# 数据库路径，不设置则使用默认路径
# DATABASE_PATH=/path/to/data.db
