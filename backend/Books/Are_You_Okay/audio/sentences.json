  },
  {
    "page": 0,
    "index": 19,
    "text": "Owl and Dog were walking to school."
  },
  {
    "page": 0,
    "index": 20,
    "text": "Dog tripped and fell."
  },
  {
    "page": 0,
    "index": 21,
    "text": "Are you okay? asked Owl."
  },
  {
    "page": 0,
    "index": 22,
    "text": "Yes, Im okay, said Dog."
  },
  {
    "page": 0,
    "index": 23,
    "text": "Owl helped Dog up."
  },
  {
    "page": 0,
    "index": 24,
    "text": "Mouse was hanging up"
  },
  {
    "page": 0,
    "index": 25,
    "text": "her backpack."
  },
  {
    "page": 0,
    "index": 26,
    "text": "She couldnt reach the hook."
  },
  {
    "page": 0,
    "index": 27,
    "text": "Can I help? asked Dog."
  },
  {
    "page": 0,
    "index": 28,
    "text": "Yes, you can help, said Mouse."
  },
  {
    "page": 0,
    "index": 29,
    "text": "Dog hung up Mouses backpack."
  },
  {
    "page": 0,
    "index": 30,
    "text": "Mouse sat down next to Lizard at lunch."
  },
  {
    "page": 0,
    "index": 31,
    "text": "Lizard looked sad."
  },
  {
    "page": 0,
    "index": 32,
    "text": "Are you okay? asked Mouse."
  },
  {
    "page": 0,
    "index": 33,
    "text": "Yes, I am okay, said Lizard."
  },
  {
    "page": 0,
    "index": 34,
    "text": "Lizard smiled at his new friend."
  },
  {
    "page": 0,
    "index": 35,
    "text": "Lizard was playing ball with Duck at recess."
  },
  {
    "page": 0,
    "index": 36,
    "text": "Duck missed the ball and couldnt find it."
  },
  {
    "page": 0,
    "index": 37,
    "text": "Do you want some help? asked Lizard."
  },
  {
    "page": 0,
    "index": 38,
    "text": "Yes, Id like some help! said Duck."
  },
  {
    "page": 0,
    "index": 39,
    "text": "Lizard and Duck found the ball."
  },
  {
    "page": 0,
    "index": 40,
    "text": "Rabbit got on the school"
  },
  {
    "page": 0,
    "index": 41,
    "text": "bus home."
  },
  {
    "page": 0,
    "index": 42,
    "text": "He saw no friends to sit with."
  },
  {
    "page": 0,
    "index": 43,
    "text": "Would you like to sit with me?"
  },
  {
    "page": 0,
    "index": 44,
    "text": "Duck asked."
  },
  {
    "page": 0,
    "index": 45,
    "text": "Yes, Id like to sit with you,"
  },
  {
    "page": 0,
    "index": 46,
    "text": "said Rabbit."
  },
  {
    "page": 0,
    "index": 47,
    "text": "Are you okay? asked Duck."
  },
  {
