[
  {
    "page": 0,
    "index": 0,
    "text": "LEVELED BOOK OF",
    "audio_file": "cadd82a32821279115a474d87358787c.mp3"
  },
  {
    "page": 0,
    "index": 1,
    "text": "Are You From India?",
    "audio_file": "8887ecc84733ea3d0b733437f7079040.mp3"
  },
  {
    "page": 0,
    "index": 2,
    "text": "Written by Katherine Follett",
    "audio_file": "9113738f49a68f6d40c844d1caa98358.mp3"
  },
  {
    "page": 0,
    "index": 3,
    "text": "Are You",
    "audio_file": "c2fb1c67d24552a97d08492b2cd0ad41.mp3"
  },
  {
    "page": 0,
    "index": 4,
    "text": "From India?",
    "audio_file": "6db0a0d530b279730e73f4613deb3238.mp3"
  },
  {
    "page": 0,
    "index": 5,
    "text": "Written by Katherine Follett",
    "audio_file": "9113738f49a68f6d40c844d1caa98358.mp3"
  },
  {
    "page": 0,
    "index": 6,
    "text": "I am from a large country called India.",
    "audio_file": "4a64a8af31b7704bdcd68ca94844c33a.mp3"
  },
  {
    "page": 0,
    "index": 7,
    "text": "Are you from India?",
    "audio_file": "aa37450d8daa1248ac390dde730c7e61.mp3"
  },
  {
    "page": 0,
    "index": 8,
    "text": "I am from India.",
    "audio_file": "b0e7951c0a97db8962c45bb92045d034.mp3"
  },
  {
    "page": 0,
    "index": 9,
    "text": "I wave my beautiful green tail.",
    "audio_file": "a88663fadd3e819acdaf480b616aa226.mp3"
  },
  {
    "page": 0,
    "index": 10,
    "text": "I am from India.",
    "audio_file": "b0e7951c0a97db8962c45bb92045d034.mp3"
  },
  {
    "page": 0,
    "index": 11,
    "text": "You may spot my dark face as I leap from tree to tree.",
    "audio_file": "461f04194271cacb2415f1857783144e.mp3"
  },
  {
    "page": 0,
    "index": 12,
    "text": "I am from India.",
    "audio_file": "b0e7951c0a97db8962c45bb92045d034.mp3"
  },
  {
    "page": 0,
    "index": 13,
    "text": "I have a wide head that looks like a hood.",
    "audio_file": "837316c86dca16db93de11a9bd1e8a38.mp3"
  },
  {
    "page": 0,
    "index": 14,
    "text": "I am from India.",
    "audio_file": "b0e7951c0a97db8962c45bb92045d034.mp3"
  },
  {
    "page": 0,
    "index": 15,
    "text": "I am as big as a house,",
    "audio_file": "b8e672327b07e56e206280f181f381a6.mp3"
  },
  {
    "page": 0,
    "index": 16,
    "text": "and I love to play in water.",
    "audio_file": "3f3bb0f5f47640848d9f408d08783b60.mp3"
  },
  {
    "page": 0,
    "index": 17,
    "text": "I am from India.",
    "audio_file": "b0e7951c0a97db8962c45bb92045d034.mp3"
  },
  {
    "page": 0,
    "index": 18,
    "text": "I have orange and black stripes, and I move silently through the forest.",
    "audio_file": "665da53df7dc2fa9d751b5d14d1e5c43.mp3"
  },
  {
    "page": 0,
    "index": 19,
    "text": "I am from India.",
    "audio_file": "b0e7951c0a97db8962c45bb92045d034.mp3"
  },
  {
    "page": 0,
    "index": 20,
    "text": "My long, thin snout has a bump on the end.",
    "audio_file": "59a4494efc11edf8b1a8bd5672789269.mp3"
  },
  {
    "page": 0,
    "index": 21,
    "text": "I am from India.",
    "audio_file": "b0e7951c0a97db8962c45bb92045d034.mp3"
  },
  {
    "page": 0,
    "index": 22,
    "text": "I am small but brave and famous for hunting snakes.",
    "audio_file": "96e81dccd5d99336ae3e528ef74d3a95.mp3"
  },
  {
    "page": 0,
    "index": 23,
    "text": "I am from India.",
    "audio_file": "b0e7951c0a97db8962c45bb92045d034.mp3"
  },
  {
    "page": 0,
    "index": 24,
    "text": "My thick, shaggy coat protects me in the cold mountains.",
    "audio_file": "88dfdce1e66d5fdd87b49fc490c8e119.mp3"
  },
  {
    "page": 0,
    "index": 25,
    "text": "All of these animals are from India, and I am from India, too.",
    "audio_file": "ed8008dfb64c2732288a04b04541627c.mp3"
  }
]