[
  {
    "page": 0,
    "index": 0,
    "text": "Animal Dads",
    "audio_file": "b37900dd7eac02df54f98c2a163a5ea7.mp3"
  },
  {
    "page": 0,
    "index": 1,
    "text": "Written by Barbara Schwartz",
    "audio_file": "ef681e47031c147df86200f3047b0b6c.mp3"
  },
  {
    "page": 0,
    "index": 2,
    "text": "Some animal dads dont help much.",
    "audio_file": "dc64fb042b7dfa6dc65f87442249ae7e.mp3"
  },
  {
    "page": 0,
    "index": 3,
    "text": "These dads dont help at all!",
    "audio_file": "f3bbf9aabc9b6eee99396833df4c324f.mp3"
  },
  {
    "page": 0,
    "index": 4,
    "text": "Worlds Greatest DAD",
    "audio_file": "b7faff0353be6ebd2a0c318ba222febe.mp3"
  },
  {
    "page": 0,
    "index": 5,
    "text": "Other animal dads are great!",
    "audio_file": "061794eabc0250af8aea31d25461443b.mp3"
  },
  {
    "page": 0,
    "index": 6,
    "text": "Which animal dads are those?",
    "audio_file": "a93b5e855334f3c0222eb3129a5f70b6.mp3"
  },
  {
    "page": 0,
    "index": 7,
    "text": "This dad guards and cares for his chicks.",
    "audio_file": "6db45ab6d6ac321ec7885afbdeeaf340.mp3"
  },
  {
    "page": 0,
    "index": 8,
    "text": "He helps them all by himself for almost two years.",
    "audio_file": "3ce22ee805e122db6e9ae7a1bf837a95.mp3"
  },
  {
    "page": 0,
    "index": 9,
    "text": "This dad cleans bugs from his babies fur.",
    "audio_file": "b9b3295f55727c0b8bae5db9c43690eb.mp3"
  },
  {
    "page": 0,
    "index": 10,
    "text": "He helps feed them.",
    "audio_file": "73fabafa092e8be75a4c639d3e4ffb74.mp3"
  },
  {
    "page": 0,
    "index": 11,
    "text": "He carries them, too.",
    "audio_file": "8fc81e38080a1bf424a97de9d7c22ff1.mp3"
  },
  {
    "page": 0,
    "index": 12,
    "text": "This dad holds eggs in his mouth.",
    "audio_file": "66014d53bc4d900a426ac0879762bfd5.mp3"
  },
  {
    "page": 0,
    "index": 13,
    "text": "He helps them stay safe until they are born.",
    "audio_file": "7d306b2a5f0339f6b3128ff445404b75.mp3"
  },
  {
    "page": 0,
    "index": 14,
    "text": "This dad eats food",
    "audio_file": "f8dddc87c9ff131d5bf0c8393ed19dfb.mp3"
  },
  {
    "page": 0,
    "index": 15,
    "text": "and spits it back up.",
    "audio_file": "68bc81b4c17b9d916f7ac8089ce40779.mp3"
  },
  {
    "page": 0,
    "index": 16,
    "text": "Then he feeds it to his pups.",
    "audio_file": "105d3efd3c3f1cce215a3b1303f8fb1c.mp3"
  },
  {
    "page": 0,
    "index": 17,
    "text": "Yum!",
    "audio_file": "1b8603fd7d48dc8e58faa1cfdba4a2e5.mp3"
  },
  {
    "page": 0,
    "index": 18,
    "text": "He helps his pups grow strong.",
    "audio_file": "b7d0414efdbbc9360d0de17260d038ed.mp3"
  },
  {
    "page": 0,
    "index": 19,
    "text": "This dad carries tadpoles on his back.",
    "audio_file": "ac36c1042c76ebbcb00b5c80c0efe9ff.mp3"
  },
  {
    "page": 0,
    "index": 20,
    "text": "He helps them reach water.",
    "audio_file": "142900abc8ebdec81e23cb2a3ff9cb47.mp3"
  },
  {
    "page": 0,
    "index": 21,
    "text": "This dad holds an egg on his feet.",
    "audio_file": "958b5f5dfa42edc6006066c03790c33a.mp3"
  },
  {
    "page": 0,
    "index": 22,
    "text": "He helps keep it warm in the cold.",
    "audio_file": "78aabdfd9b7d4ae5ebcca0511dcd3a27.mp3"
  },
  {
    "page": 0,
    "index": 23,
    "text": "This dad holds thousands of eggs in his pouch.",
    "audio_file": "388957d4b19fa004e176fb8b9e83c1a9.mp3"
  },
  {
    "page": 0,
    "index": 24,
    "text": "He helps them grow and hatch.",
    "audio_file": "b2c3f9f02d5228cfb7ea16161fcfe0e6.mp3"
  },
  {
    "page": 0,
    "index": 25,
    "text": "These dads help out with their young, too!",
    "audio_file": "7c3771a433674a0f8e351eafb3737d95.mp3"
  }
]